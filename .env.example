SAP_URL=https://example.com:443
SAP_USERNAME=your_username
SAP_PASSWORD=your_password
SAP_CLIENT=your_client_number
SAP_LANGUAGE=en
TLS_REJECT_UNAUTHORIZED=either_1_or_0

# Transport: "stdio" (default) or "http" for Streamable HTTP (Docker/Kubernetes)
MCP_TRANSPORT=stdio
# Port used only when MCP_TRANSPORT=http
PORT=8080
